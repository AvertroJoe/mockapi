# ── Server config ─────────────────────────────────────────────
# Secret token required on all /admin/* requests (Authorization: Bearer <token>)
# The server refuses to start if this is unset or left as "changeme" — set a
# real, random value before deploying.
ADMIN_TOKEN=change-me-before-deploy

# Directory where config and uploaded files are stored (inside the container)
DATA_DIR=/data

# ── CLI config ────────────────────────────────────────────────
# Base URL of the running MockAPI server
MOCKAPI_URL=http://localhost:8000

# Must match ADMIN_TOKEN above
MOCKAPI_ADMIN_TOKEN=change-me-before-deploy
